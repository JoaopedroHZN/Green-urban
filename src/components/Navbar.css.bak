/* ===== Navbar Glassmorphism ===== */
.navbar { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; }
.navbar-container { max-width: 1280px; margin: 0 auto; padding: 0 20px; height: 64px; }
.navbar-logo-img { height: 34px; width: auto; object-fit: contain; flex-shrink: 0; }
.nav-menu { display: flex; align-items: center; gap: 4px; list-style: none; margin: 0; padding: 0; }
.nav-item { margin: 0; }
.nav-link { text-decoration: none; font-size: 0.875rem; font-weight: 500; padding: 6px 14px; border-radius: 12px; transition: all 0.2s ease; position: relative; }
.nav-link::after { display: none; }
.nav-link.active { background: #ecfdf5; font-weight: 700; }
.hamburger { display: none; flex-direction: column; justify-content: center; align-items: center; gap: 5px; width: 40px; height: 40px; background: transparent; border: none; border-radius: 8px; cursor: pointer; padding: 8px; transition: background 0.2s; }
.hamburger:hover { background: rgba(0,0,0,0.05); }
.bar { display: block; width: 22px; height: 2.5px; background: #334155; border-radius: 2px; transition: all 0.3s ease; }
.hamburger.active .bar:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
.hamburger.active .bar:nth-child(2) { opacity: 0; transform: translateX(-8px); }
.hamburger.active .bar:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
.nav-link-login { color: #059669 !important; font-weight: 600; border: 2px solid #059669; border-radius: 50px; padding: 6px 18px; background: transparent; }
.nav-link-login:hover { background: #ecfdf5; border-color: #047857; color: #047857 !important; transform: translateY(-1px); }
.nav-link-login.active { background: #ecfdf5; border-color: #047857; }
.nav-link-cadastro { color: #ffffff !important; font-weight: 600; border: 2px solid #059669; border-radius: 50px; padding: 6px 18px; background: #059669; }
.nav-link-cadastro:hover { background: #047857; border-color: #047857; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(5,150,105,0.25); }
.nav-link-cadastro.active { background: #047857; border-color: #047857; }
.nav-item-user { display: flex; align-items: center; }
.nav-user-greeting { font-size: 0.875rem; color: #475569; padding: 6px 12px; font-weight: 500; }
.nav-user-greeting strong { color: #059669; font-weight: 700; }
.nav-link-logout { color: #ef4444 !important; font-weight: 600; border: 2px solid #fca5a5; border-radius: 50px; padding: 6px 18px; background: transparent; cursor: pointer; font-size: 0.875rem; }
.nav-link-logout:hover { background: #fef2f2; border-color: #ef4444; color: #dc2626 !important; transform: translateY(-1px); }
@media (max-width: 1024px) { .nav-link { padding: 6px 10px; font-size: 0.8rem; } .nav-link-login, .nav-link-cadastro, .nav-link-logout { padding: 6px 14px; } }
@media (max-width: 768px) { .hamburger { display: flex; } .nav-menu { position: fixed; top: 64px; left: 0; width: 100%; background: rgba(255,255,255,0.98); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); flex-direction: column; gap: 2px; padding: 16px 20px 24px; border-bottom: 1px solid #e2e8f0; box-shadow: 0 12px 40px rgba(0,0,0,0.08); transform: translateY(-120%); opacity: 0; pointer-events: none; transition: all 0.35s cubic-bezier(0.4,0,0.2,1); z-index: 999; } .nav-menu.active { transform: translateY(0); opacity: 1; pointer-events: all; } .nav-link { display: flex; width: 100%; padding: 12px 18px; font-size: 1rem; text-align: left; justify-content: flex-start; } .nav-link:hover { background: #f0fdf4; } .nav-link-login, .nav-link-cadastro, .nav-link-logout { justify-content: center; width: 100%; padding: 10px 18px; font-size: 0.95rem; } .nav-item-user { justify-content: center; width: 100%; } .nav-user-greeting { text-align: center; width: 100%; padding: 10px 18px; justify-content: center; } }
